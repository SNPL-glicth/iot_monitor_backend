# Example env for iot_monitor_backend
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

DB_DIALECT=mssql
DB_HOST=localhost
DB_PORT=1434
DB_USER=sa
DB_PASSWORD=YourStrongPasswordHere
DB_NAME=iot_monitoring_system
PORT=3000

# JWT secrets - generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_64_hex_chars_minimum_for_security
REFRESH_TOKEN_SECRET=change_me_to_a_different_64_hex_chars_value

# CORS origins (comma-separated). In production, restrict to your actual domains.
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Cookie security
# COOKIE_SECURE=1
# COOKIE_SAMESITE=strict
# COOKIE_DOMAIN=yourdomain.com

# Internal API key for service-to-service communication
# INTERNAL_API_KEY=generate_a_strong_random_key_here

# Push notifications (optional)
# FCM_SERVER_KEY=your_fcm_server_key

# Critical alert emails (optional)
# CRITICAL_ALERT_EMAILS=admin@yourdomain.com,ops@yourdomain.com
# SMTP_API_URL=https://your-smtp-provider.com/api/v1/send

# Disable ML events polling to avoid duplication with event-driven system
REALTIME_POLL_ML_EVENTS=false

# Ingest endpoint for devices
INGEST_URL=http://localhost:8001/ingest/packets

# Internal Service-to-Service Keys for Sensor Provisioning
INGEST_INTERNAL_KEY=       # Used by NestJS to authenticate against FastAPI
INTERNAL_API_KEY=          # Used by FastAPI to validate NestJS service calls
